generator client {
  provider = "prisma-client"
  output  = "./generated"
}

datasource db {
  provider = "postgresql"
}


model User { 
  id    Int     @id @default(autoincrement()) 
  email String  @unique
  password String
  profile Profile?
  @@map("Users")
} 

model Profile{
  id Int @id @default(autoincrement())
  userId Int @unique
  nickname String @unique
  avatar String?
  birthday String?,
  user User @relation(fields:[userId],references:[id])


  @@map("profiles")
}
